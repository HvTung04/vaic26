APP_ENV=dev
DATABASE_URL=postgresql+psycopg://gaplens:gaplens@localhost:5432/gaplens

# LLM provider chua chot (xem plan.md muc 0). Bo trong -> get_llm() tra ve FakeChatModel
# de code khac van chay duoc. Khi chot: LLM_PROVIDER=anthropic|openai|google_genai...,
# LLM_MODEL=<model id>. Khong can sua code, chi can set 2 bien nay.
LLM_PROVIDER=
LLM_MODEL=
LLM_API_KEY=

# Fake auth cho 2 account demo (giao vien / hoc sinh) - xem plan.md muc 1 (BE/AI 3)
FAKE_TEACHER_TOKEN=teacher-demo-token
FAKE_STUDENT_TOKEN=student-demo-token
